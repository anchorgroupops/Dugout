.env
.env.*
!.env.example
.tmp/
.venv/
node_modules/
__pycache__/
*.pyc
data/
# But DO ship the bundled empty-state fallbacks under client/public/data/sharks/.
# These ride along inside the dashboard image so nginx can serve them when
# the live Pi data volume hasn't seeded a file yet (fresh deploy, sick API).
# We re-include only the sharks/ subdir; ad-hoc root-level files in
# client/public/data/ stay ignored so dev scratch doesn't leak into the
# image.
!client/public/data/
!client/public/data/sharks/
!client/public/data/sharks/**
*.db
.DS_Store
credentials/
secrets.json
auth.json
**/*.key
**/*.pem
**/*.cert
**/*.csr
dist/
tools/frida-server
tools/frida-server.xz
# Generated dev-mode PWA service worker (Vite VitePWA devOptions)
client/dev-dist/
# Claude Code internal agent state — never commit
.claude/worktrees/
# Runtime logs (generated on Pi, not source-controlled)
logs/
tools/logs/
# Scratch files
install.log
list.txt
# Security: never commit secrets or sensitive files
APIs*.csv
architecture/APIs*.csv
secrets.json
# Separate repo (anchorgroupops/Dugout) — don't nest
Dugout/
# Binary artifacts
*.apk
# Coverage / test artifacts
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.hypothesis/
# Temp/editor files
~

# squirrelscan CLI
squirrel.toml

# Output files that tools write — should stay in logs/ not repo root
tools/*.txt
tools/*.log
*.log

# Frida / Android debug binaries
tools/frida-server*
tools/*.xz
tools/*.js

# Windows-path scripts (never cross-compile correctly)
gen_b64*.py
