# =============================================================================
# Sharks Softball Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- GameChanger credentials ------------------------------------------------
GC_EMAIL=your_email@example.com
GC_PASSWORD=your_password
# Team ID from the GC URL: web.gc.com/teams/<GC_TEAM_ID>/...
GC_TEAM_ID=your_team_id_here
# Season slug from GC URL, e.g. "2025-spring" or "2025"
GC_SEASON_SLUG=2025-spring
# Comma-separated org IDs (visible in GC admin/org URLs)
GC_ORG_IDS=your_org_id_here

# --- AI / LLM services -------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_API_KEY=your_google_api_key
PINECONE_API_KEY=your_pinecone_api_key

# --- Voice synthesis (ElevenLabs) -------------------------------------------
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# Voice ID from ElevenLabs voice library (leave blank to use built-in fallback)
ELEVENLABS_VOICE_ID=your_voice_id_here

# --- Google / NotebookLM integration ----------------------------------------
# Google Doc ID used by notebooklm_sync.py to push SWOT/scout data
GOOGLE_DOC_ID=your_google_doc_id_here
# NotebookLM notebook name to sync
NOTEBOOKLM_NOTEBOOK=PCLL 🥎

# --- Deploy webhook ----------------------------------------------------------
# Token used by GitHub Actions to POST /api/deploy and trigger a Pi redeploy.
# Generate with: openssl rand -hex 32
DEPLOY_WEBHOOK_TOKEN=replace_with_a_secure_random_token

# --- Team metadata -----------------------------------------------------------
TEAM_NAME=The Sharks
LEAGUE=PCLL
DIVISION=Majors

# --- Site domain (used by CORS, deploy scripts) --------------------------------
SITE_DOMAIN=dugout.joelycannoli.com

# --- Cloudflare (tunnel configuration) ----------------------------------------
CLOUDFLARE_EMAIL=your_email@example.com
CLOUDFLARE_API_KEY=your_cloudflare_api_key

# --- Announcer TTS (walk-up music + player announcements) -------------------
# Replicate API token for Qwen3-TTS (primary). Falls back to ElevenLabs if unset.
REPLICATE_API_TOKEN=r8_your_token_here
# Reference audio for voice cloning (URL to a short MP3 of the desired voice)
ANNOUNCER_VOICE_REF_URL=https://example.com/steitzer-reference.mp3
# Transcript matching the reference audio (for clone mode alignment)
ANNOUNCER_VOICE_REF_TEXT=Now batting, number seven, Sophia!

# --- Optional: Firecrawl (web research agent) --------------------------------
FIRECRAWL_API_KEY=fc-your_key_here

# --- Optional: Secrets CSV path (alternative to .env for multi-key setups) ---
# SECRETS_CSV=/path/to/APIs.csv

# --- GC CSV autopull ---------------------------------------------------------
GC_AUTOPULL_ENABLED=false
GC_AUTOPULL_POSTGAME_ENABLED=false
GC_AUTOPULL_LLM_ADAPT=false
GC_AUTOPULL_IDEMPOTENCY_WINDOW_MIN=15
GC_AUTOPULL_LLM_DAILY_BUDGET_USD=1.00
GC_AUTOPULL_LLM_MODEL=claude-sonnet-4-6

# Gmail OAuth (headless) for 2FA code read + failure notifications
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
GMAIL_NOTIFY_FROM=anchorgroupops@gmail.com
GMAIL_NOTIFY_TO=anchorgroupops@gmail.com

# Anthropic API for LLM-adaptive locator fallback
ANTHROPIC_API_KEY=

# n8n webhooks
N8N_AUTOPULL_STATUS_WEBHOOK=https://n8n.joelycannoli.com/webhook/gc-pull-status
N8N_AUTOPULL_WEEKLY_WEBHOOK=https://n8n.joelycannoli.com/webhook/autopull-weekly

# Push notifications (ntfy.sh, Pushover, or any HTTP POST endpoint that
# delivers to your phone). Leave empty to disable push.
PUSH_WEBHOOK_URL=
