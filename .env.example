# =============================================================================
# Dugout — Softball Strategy Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- GameChanger credentials ------------------------------------------------
GC_EMAIL=your_email@example.com
GC_PASSWORD=your_password
# Team ID from the GC URL: web.gc.com/teams/<GC_TEAM_ID>/...
GC_TEAM_ID=your_team_id_here
# Season slug from GC URL, e.g. "2025-spring" or "2025"
GC_SEASON_SLUG=2025-spring
# Comma-separated org IDs (visible in GC admin/org URLs)
GC_ORG_IDS=your_org_id_here

# --- AI / LLM services -------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_API_KEY=your_google_api_key
PINECONE_API_KEY=your_pinecone_api_key

# --- Voice synthesis (ElevenLabs) -------------------------------------------
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# Voice ID from ElevenLabs voice library (leave blank to use built-in fallback)
ELEVENLABS_VOICE_ID=your_voice_id_here

# --- Google / NotebookLM integration ----------------------------------------
# Google Doc ID used by notebooklm_sync.py to push SWOT/scout data
GOOGLE_DOC_ID=your_google_doc_id_here
# NotebookLM notebook name to sync
NOTEBOOKLM_NOTEBOOK=PCLL 🥎

# --- Deploy webhook ----------------------------------------------------------
# Token used by GitHub Actions to POST /api/deploy and trigger a Pi redeploy.
# Generate with: openssl rand -hex 32
DEPLOY_WEBHOOK_TOKEN=replace_with_a_secure_random_token

# --- Cloudflare (tunnel configuration) --------------------------------------
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=

# --- Team metadata -----------------------------------------------------------
TEAM_NAME=The Sharks
TEAM_SLUG=sharks
LEAGUE=PCLL
DIVISION=Majors

# --- Optional: Firecrawl (web research agent) --------------------------------
FIRECRAWL_API_KEY=fc-your_key_here

# --- IMAP (auto-read GameChanger 2FA codes from email) ---------------------
# Required for automatic 2FA code retrieval. Generate an App Password at:
#   https://myaccount.google.com/apppasswords
GC_IMAP_EMAIL=fly386@gmail.com
GC_IMAP_APP_PASSWORD=

# --- Proxy (route Playwright through a fixed IP) ---------------------------
# Set to route scraping through a SOCKS5 proxy (e.g. SSH tunnel to Pi):
#   ssh -D 1080 -N joely@192.168.7.222
#   GC_PROXY_SERVER=socks5://localhost:1080
GC_PROXY_SERVER=

# --- Optional: Secrets CSV path (alternative to .env for multi-key setups) ---
# SECRETS_CSV=/path/to/APIs.csv
